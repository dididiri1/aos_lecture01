<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/course_card_bg"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/course_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/courseThumbnail"
            android:layout_width="96dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_course_thumbnail"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            tools:src="@drawable/react1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/courseBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/course_badge_text"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="LIVE" />

            <TextView
                android:id="@+id/courseTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/course_title_text"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="강좌명" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
