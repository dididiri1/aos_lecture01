<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_sentence_card"
    android:padding="16dp"
    tools:context=".SentenceActivity">

    <!-- 명언 본문 -->
    <TextView
        android:id="@+id/sentenceItemTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textColor="@color/sentence_text"
        android:lineSpacingExtra="4dp"
        tools:text="성공은 최종적인 것이 아니고, 실패는 치명적인 것이 아니다." />

    <!-- 저자 -->
    <TextView
        android:id="@+id/sentenceItemAuthor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="end"
        android:textSize="13sp"
        android:textColor="@color/sentence_author"
        tools:text="- 윈스턴 처칠" />

</LinearLayout>
